---
import type { PracticeTask } from "@data/modules";

type Props = {
  tasks: PracticeTask[];
};

const { tasks } = Astro.props;
---

<section>
  <h2>Practice Tasks</h2>
  <div class="task-list">
    {
      tasks.map((task) => (
        <article class="task">
          <span class="meta">{task.minutes} min</span>
          <h3>{task.title}</h3>
          <p>{task.description}</p>
        </article>
      ))
    }
  </div>
</section>
