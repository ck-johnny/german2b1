const tokenizeGerman = (text: string) => text.match(/[A-Za-zÄÖÜäöüß]+(?:-[A-Za-zÄÖÜäöüß]+)?|\d+/g) ?? [];

const makeGlossLookup = () => {
  const lookup = new Map<string, string>();

  Object.entries(commonGlosses).forEach(([word, gloss]) => {
    lookup.set(word, gloss);
    const lowerWord = word.toLocaleLowerCase("de-DE");
    if (word === lowerWord) lookup.set(lowerWord, gloss);
  });

  module.vocabulary.forEach((item) => {
    lookup.set(item.de, item.en);
    lookup.set(item.de.toLocaleLowerCase("de-DE"), item.en);
  });

  return lookup;
};

const glossLookup = makeGlossLookup();
const bankGroups = getSentenceBankGroups(module, extra);
const bankItems = bankGroups.flatMap((group) => group.items);

const getWordGlosses = (text: string) =>
  tokenizeGerman(text).map((word) => ({
    word,
    gloss:
      glossLookup.get(word) ??
      glossLookup.get(word.toLocaleLowerCase("de-DE")) ??
      "see sentence meaning",
  }));

const makeCategoryId = (category: string) =>
  `${module.id}-${category
    .toLocaleLowerCase("en")
    .replaceAll("/", "")
    .replaceAll(" ", "-")}`;
---

{
  (extra || bankItems.length > 0) && (
    <>
      {extra && (
        <section>
          <h2>Pronunciation Notes</h2>
          <div class="study-extra-list">
            {extra.pronunciation.map((note) => (
              <article class="study-extra-card">
                <GermanText text={note.de} strong />
                <p>{note.en}</p>
              </article>
            ))}
          </div>
        </section>
      )}

      <section>
        <h2>Sentences to Know</h2>
        <div class="language-bank-groups">
          {bankGroups.map((group) => (
            <section class="bank-group" aria-labelledby={makeCategoryId(group.category)}>
              <h3 id={makeCategoryId(group.category)}>{group.category}</h3>
              <div class="language-bank">
                {group.items.map((item) => (
                  <details class="bank-card">
                    <summary>
                      <span class="bank-card-main">
                        <span class="meta">{item.label}</span>
                        <GermanText text={item.de} strong block />
                        <span>{item.en}</span>
                      </span>
                    </summary>
                    <div class="word-gloss-list" aria-label={`Word meanings for ${item.de}`}>
                      {getWordGlosses(item.de).map((token) => (
                        <span class="word-gloss">
                          <GermanText text={token.word} display={token.word} />
                          <small>{token.gloss}</small>
                        </span>
                      ))}
                    </div>
                  </details>
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>
    </>
  )
}
