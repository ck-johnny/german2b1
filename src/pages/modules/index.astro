---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getModulesByLevel, levels } from "@data/modules";
import { withBasePath } from "@utils/paths";
---

<BaseLayout title="Modules · German2B1" description="All German2B1 modules from A1 to B1.">
  <header class="compact-page-title">
    <span class="meta">The German path</span>
    <h1>Modules</h1>
    <p>Eighteen module pages, level-by-level, with cheat sheets, tasks, and micro-checks.</p>
  </header>

  {
    levels.map((level) => (
      <section id={level.toLowerCase()} class="level-band">
        <h2>{level} · {getModulesByLevel(level).length} modules</h2>
        <div class="module-list">
          {getModulesByLevel(level).map((module) => (
            <a class="module-row" href={withBasePath(`/modules/${module.id}`)}>
              <span class="module-n">{String(module.order).padStart(2, "0")}</span>
              <div class="module-mid">
                <div class="module-title-row">
                  <h3>{module.title}</h3>
                  <span class="module-theme">{module.theme}</span>
                </div>
                <p>{module.summary}</p>
              </div>
              <div class="module-right">
                <span class="module-min">{module.tasks.reduce((sum, t) => sum + t.minutes, 0)} min</span>
                <span class="arrow">→</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))
  }
</BaseLayout>
