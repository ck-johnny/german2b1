---
import A1Readiness from "@components/A1Readiness.astro";
import CheatSheet from "@components/CheatSheet.astro";
import MicroCheck from "@components/MicroCheck.astro";
import ResourceList from "@components/ResourceList.astro";
import StudyExtras from "@components/StudyExtras.astro";
import TaskList from "@components/TaskList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getAdjacentModules, getModuleById, modules } from "@data/modules";
import { getResourcesByIds } from "@data/resources";
import { getStudyExtra } from "@data/studyExtras";
import { topics } from "@data/topics";
import { withBasePath } from "@utils/paths";
import { getSentenceBank } from "@utils/sentenceBank";

export function getStaticPaths() {
  return modules.map((module) => ({
    params: { id: module.id },
  }));
}

const module = getModuleById(Astro.params.id ?? "");

if (!module) {
  return Astro.redirect("/modules");
}

const officialResources = getResourcesByIds(module.resourceIds);
const studyExtra = getStudyExtra(module.id);
const sentenceBank = getSentenceBank(module, studyExtra);
const { next: nextModule } = getAdjacentModules(module.id);
const relatedTopics = topics
  .filter((topic) => topic.moduleIds.includes(module.id))
  .slice(0, 4);
const totalMinutes = module.tasks.reduce((sum, task) => sum + task.minutes, 0);
---

<BaseLayout title={`${module.id.toUpperCase()} · ${module.title} · German2B1`} description={module.summary}>
  <nav class="crumb" aria-label="Breadcrumb">
    <a href={withBasePath("/")}>Start</a>
    <span>/</span>
    <a href={withBasePath("/modules")}>Modules</a>
    <span>/</span>
    <span>{module.id.toUpperCase()}</span>
  </nav>

  <header class="mod-hero">
    <div class="mod-meta">
      <span class="mod-tag">{module.level}</span>
      <span class="mod-tag mod-tag-soft">Module {String(module.order).padStart(2, "0")}</span>
      <span class="meta">{module.theme}</span>
    </div>
    <h1>{module.title}</h1>
    <p class="lead">{module.summary}</p>
    <div class="goal">
      <span class="meta">Goal</span>
      <p>{module.goalEn}</p>
      <div class="pill-row">
        {module.targetItems.map((item) => <span class="pill">{item}</span>)}
      </div>
    </div>
  </header>

  <div class="module-layout module-grid">
    <article class="reader">
      <CheatSheet module={module} />
      {module.level === "A1" && <A1Readiness moduleId={module.id} />}
      <StudyExtras extra={studyExtra} module={module} />
      <TaskList tasks={module.tasks} />
      <MicroCheck checks={module.microChecks} />

      <section>
        <h2>Search Prompts</h2>
        <div class="task-list">
          <article class="task">
            <span class="meta">English</span>
            <p>{module.searchPrompts.en}</p>
          </article>
        </div>
      </section>

      <section>
        <h2>Official Links</h2>
        <ResourceList resources={officialResources} />
      </section>
    </article>

    <aside class="mod-side">
      <div class="side-card">
        <span class="meta">Progress</span>
        <div class="prog-num">0 / {module.tasks.length}</div>
        <div class="prog-bar"><span style="width: 0%"></span></div>
        <p class="side-text">
          Mark a task as done once you have actually said or written the result aloud.
        </p>
      </div>
      <div class="side-card">
        <span class="meta">Exam bridge</span>
        <p class="side-strong">{module.examBridge}</p>
        <p class="side-text">
          {sentenceBank.length} listenable sentences · {module.grammar.length} grammar notes · {totalMinutes} min of practice.
        </p>
      </div>
      {
        relatedTopics.length > 0 && (
          <div class="side-card">
            <span class="meta">Related topics</span>
            <ul class="side-links">
              {relatedTopics.map((topic) => (
                <li>
                  <a href={withBasePath(`/topics/${topic.id}`)}>{topic.title}</a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
      {
        nextModule && (
          <div class="side-card">
            <span class="meta">Next module</span>
            <p class="side-strong">
              {nextModule.id.toUpperCase()} · {nextModule.title}
            </p>
            <a class="button secondary" href={withBasePath(`/modules/${nextModule.id}`)}>
              Open →
            </a>
          </div>
        )
      }
    </aside>
  </div>
</BaseLayout>
