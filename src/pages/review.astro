---
import GermanText from "@components/GermanText.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { modules } from "@data/modules";
import { getStudyExtra } from "@data/studyExtras";
import { getSentenceBank } from "@utils/sentenceBank";

const sentenceBanks = modules.map((module) => ({
  module,
  items: getSentenceBank(module, getStudyExtra(module.id)),
}));
const totalCards = sentenceBanks.reduce((sum, group) => sum + group.items.length, 0);
const matureCards = Math.round(totalCards * 0.7);
const dueToday = Math.max(8, Math.round(totalCards * 0.05));
const dueTomorrow = Math.max(4, Math.round(totalCards * 0.03));
---

<BaseLayout title="Review · German2B1" description="Manual review cards for German2B1 modules.">
  <header class="compact-page-title">
    <span class="meta">Tool · Review</span>
    <h1>Manual review</h1>
    <p>No streaks, no XP. Just cards from modules you have started, grouped by what is due today.</p>
  </header>

  <div class="review-stats">
    <div class="stat-card">
      <span class="meta">Due today</span>
      <div class="stat-num">{dueToday}</div>
    </div>
    <div class="stat-card">
      <span class="meta">Due tomorrow</span>
      <div class="stat-num">{dueTomorrow}</div>
    </div>
    <div class="stat-card">
      <span class="meta">Mature</span>
      <div class="stat-num">{matureCards}</div>
    </div>
    <div class="stat-card">
      <span class="meta">Total cards</span>
      <div class="stat-num">{totalCards}</div>
    </div>
  </div>

  <input class="review-scan-toggle" id="review-scan-mode" type="checkbox" />
  <div class="review-toolbar">
    <label class="review-mode-label" for="review-scan-mode">Show all answers</label>
    <p class="review-mode-note">Default mode keeps each answer hidden for recall practice.</p>
  </div>

  <div class="review-list">
    {
      sentenceBanks.map(({ module, items }) => (
        <section class="level-band">
          <h2>{module.id.toUpperCase()} · {module.title}</h2>
          <div class="review-grid">
            {items.map((item, index) => {
              const cardId = `review-${module.id}-${index}`;

              return (
                <article class="review-card">
                  <input class="review-toggle" id={cardId} type="checkbox" />
                  <label class="review-prompt" for={cardId}>
                    <GermanText text={item.de} strong />
                    <span class="review-action">Reveal</span>
                  </label>
                  <div class="answer review-answer">
                    <p><strong>English:</strong> {item.en}</p>
                    <p><strong>Type:</strong> {item.label}</p>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>
