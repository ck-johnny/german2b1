---
import { basicModules } from "@data/basics";
import BaseLayout from "@layouts/BaseLayout.astro";
import { withBasePath } from "@utils/paths";
---

<BaseLayout title="Basics · German2B1" description="Zero-knowledge German basics split into compact A1 study modules.">
  <header class="compact-page-title">
    <span class="meta">A1 · Foundations</span>
    <h1>Basics</h1>
    <p>If German is completely new, start here. Each basics module is short enough to study directly.</p>
  </header>

  <section class="level-band">
    <h2>A1 Basics · {basicModules.length} modules</h2>
    <div class="module-list">
      {
        basicModules.map((module) => (
          <a class="module-row" href={withBasePath(`/basics/${module.id}`)}>
            <span class="module-n">{String(module.order).padStart(2, "0")}</span>
            <div class="module-mid">
              <div class="module-title-row">
                <h3>{module.title}</h3>
                <span class="module-theme">{module.focus.slice(0, 2).join(" · ")}</span>
              </div>
              <p>{module.summary}</p>
            </div>
            <div class="module-right">
              <span class="module-min">{module.sectionIds.length} sections</span>
              <span class="arrow">→</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
